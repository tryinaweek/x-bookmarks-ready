{
  "manifest_version": 3,
  "name": "X-Bookmarks",
  "version": "1.0.2",
  "description": "Seamlessly sync your X/Twitter Bookmarks directly to your MyBookmarks dashboard.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/my-items/saved-posts/*",
        "https://www.linkedin.com/my-items/saved-posts"
      ],
      "js": ["linkedin_content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5001/*",
        "http://127.0.0.1:5001/*",
        "https://*.vercel.app/*",
        "https://xbookmarksync.com/*",
        "https://*.xbookmarksync.com/*"
      ],
      "js": ["dashboard-helper.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://*.vercel.app/*",
      "https://xbookmarksync.com/*",
      "https://*.xbookmarksync.com/*"
    ]
  }
}
